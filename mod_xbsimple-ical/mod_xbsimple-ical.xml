					layout="joomla.form.field.subform.default"
					showon="showinfo:1"
				>
					<form>
				        <field name="startfmt" type="text"
				        	label="XBIC_START_TIME_FMT"
				        	default="G:i"
				        	filter="raw"
				        />
				        <field name="endfmt" type="text"
				        	label="XBIC_END_TIME_FMT"
				        	default=" \- G:i"
				        	filter="raw"
				        />
					</form>					
				</field>

				<field type="spacer" 
				        name="detsspacer" 
				        hr="true"
				/>
				<field name="showdetails" type="radio"
					label="XBIC_DETS_SHOW"
					description="XBIC_DETS_SHOW_DESC"
					default="0"
					class="btn-group btn-group-yesno"
				>
					<option value="0">JHIDE</option>
					<option value="1">XBIC_POPUP</option>
					<option value="2">XBIC_DROPDOWN</option>
					<option value="3">XBIC_FULL</option>
				</field>
				
				<field name="detailsprompt" type="text"
					label="XBIC_DETS_PROMPT"
					description="XBIC_DETS_PROMPT_DESC"
					default="more info ..."
					showon="showdetails:1[OR]showdetails:2"
				/>
				
				<field name="detailscomps" type="subform"
			        label="XBIC_DETS_SHOW"
			        description="XBIC_DETS_SHOW_DESC"
			        multiple="true" min="0"  max="5"
					buttons= "add,remove,move"
					showon="showdetails!:0"
					layout="joomla.form.field.subform.repeatable-table"
				>
				    <form>
				        <field name="comp" type="list"
				        	label="XBIC_CAL_COMPS"
				        >
				          <option value="description">XBIC_DESCRIPTION</option>
				          <option value="categories">XBIC_CATEGORIES</option>
				          <option value="location">XBIC_LOCATION</option>
				          <option value="summary">XBIC_SUMMARY</option>
				          <option value="startdate">XBIC_START_DATE</option>
				          <option value="starttime">XBIC_START_TIME</option>
				          <option value="enddate">XBIC_END_DATE</option>
				          <option value="endtime">XBIC_END_TIME_DURATION</option>
				          <option value="repeats">XBIC_REPEATS</option>
				          <option value="calendar">XBIC_CALENDAR</option>
				        </field>
				        <field name="compprefix" type="text"
				        	label="XBIC_PREFIX"
				        	hint="XBIC_PRESUF_HINT"
