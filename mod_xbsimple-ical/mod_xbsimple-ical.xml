				        />
				        <field name="compsuffix" type="text"
				        	label="XBIC_SUFFIX"
				        	hint="XBIC_PRESUF_HINT"
				        	filter="raw"
				        />
						<field name="compname" type="hidden" default="details" />
				    </form>
				</field>
				
				<field name="detailsdatefmt" type="subform"
					label="XBIC_DETAILS_DATE_FMT"
					description="XBIC_DATE_FMT_DESC"
					multiple="false"
					layout="joomla.form.field.subform.default"
					showon="showdetails!:0"
				>
					<form>
				        <field name="startfmt" type="text"
				        	label="XBIC_START_DATE_FMT"
				        	default="D jS \of M"
