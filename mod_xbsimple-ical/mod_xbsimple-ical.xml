	<config>
		<fields name="params"
			addruleprefix="Crosborne\Module\Xbsimpleical\Site\Rule"
		>
			<fieldset name="basic">
			
				<field name="calendars" type="subform"
			        label="XBIC_CALENDAR_S"
			        description="XBIC_CALS_DESC"
			        multiple="true"
			        min="1"  max="4"
					buttons= "add,remove"
                  	layout="joomla.form.field.subform.repeatable" 
                  	class="form-horizontal"
				>
				    <form>
				        <field name="calurl" type="text"
				        	label="XBIC_CALS_URL_ID"
                            size="80"
				        	hint="XBIC_CAL_HINT"
				        >
				        </field>
				        <field name="calname" type="text"
				        	label="XBIC_CAL_NAME"
				        	hint="XBIC_CAL_NAME_HINT"
				        />
						<field
					        name="calbkgnd" type="color" 
					        label="XBIC_CAL_BGCOLOUR"
					        format="rgba"
					        default="" 
						/>
                    </form>
				</field>
				
<!-- calendar_id field will be removed once all installs have updated to calendars -->
				<field name="calendar_id" type="text" default="" label="MOD_SIMPLEICALBLOCK_CALENDAR_ID" description="MOD_SIMPLEICALBLOCK_CALENDAR_ID_DESC" />
<!-- xxxxxxxxxxxxxxx -->	
			
				<field name="event_count" type="number" 
					label="XBIC_CNT_EVENTS" 
					description="XBIC_CNT_EVENTS_DESC" 
					min="0" max="100" default="10"  
				/>
				
				<field name="event_period" type="number" 
					label="XBIC_PR_EVENTS" 
					description="XBIC_PR_EVENTS_DESC" 
					min="0" max="730" default="92"  
				/>
				
			</fieldset>

			<fieldset name="layout" label="XBIC_LAYOUT">
			
              	<field name="layoutnote" type="note" 
              		description="XBIC_LAYOUT_OPTS_NOTE" 
              	/>

				<field name="showcal" type="radio"
					label="XBIC_SHOWCAL"
					description="XBIC_SHOWCAL_DESC"
					class="btn-group btn-group-yesno"
					default="0"
				>
					<option value="0">JHIDE</option>
					<option value="1">JSHOW</option>
				</field>
				
				<field name="showcats" type="radio"
					label="XBIC_SHOWCATS"
					description="XBIC_SHOWCATS_DESC"
					class="btn-group btn-group-yesno"
					default="0"
				>
					<option value="0">JHIDE</option>
					<option value="1">JSHOW</option>
				</field>
				
				<field name="endtype" type="radio"
					label="XBIC_END_OR_DUR"
					description="XBIC_END_OR_DUR_DESC"
					class="btn-group btn-group-yesno"
					default="0"
				>
					<option value="0">XBIC_IGNORE_END</option>
					<option value="1">XBIC_END_AS_TIME</option>
					<option value="2">XBIC_END_AS_DURATION</option>					
				</field>
				
				<field name="dtfmthelp" type="note"
					description="XBIC_TIMEFORMAT_HELP"
				/>				
				
				<field name="durationfmt" type="text"
					label="XBIC_DURATION_FMT"
					description="XBIC_DURATION_FMT_DESC"
					default=" G\h\r\s i\m\i\n\s"
					showon="endtype:2"
				/>
				
				<field name="repicon" type="radio"
					label="XBIC_REPICON"
					description="XBIC_REPICON_DESC"
					class="btn-group btn-group-yesno"
					default="1"
				>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				
				<field name="nosection" type="note"
					description="XBIC_WARN_NO_SECTIONS"
					showon="headtype:0[AND]showtitle:0[AND]showinfo:0[AND]showdetails:0"
