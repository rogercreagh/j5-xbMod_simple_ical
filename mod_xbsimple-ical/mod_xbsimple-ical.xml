				        <field name="endfmt" type="text"
				        	label="XBIC_END_TIME_FMT"
				        	default=" - G:i"
				        	filter="raw"
				        />
					</form>					
				</field>
 								
				<field type="spacer" 
				        name="infospacer" 
				        hr="true"
				/>
				<field name="showinfo" type="radio"
					label="XBIC_INFO_SHOW"
					description="XBIC_INFO_SHOW_DESC"
					default="0"
					class="btn-group btn-group-yesno"
				>
					<option value="0">JHIDE</option>
					<option value="1">JSHOW</option>
				</field>
				
				<field name="infocomps" type="subform"
			        label="XBIC_INFO_COMPS"
			        description="XBIC_INFO_COMPS_DESC"
