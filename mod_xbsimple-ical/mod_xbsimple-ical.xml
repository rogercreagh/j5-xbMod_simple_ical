			</fieldset>

			<fieldset name="layout" label="XBIC_LAYOUT">
			
              	<field name="layoutnote" type="note" 
              		description="XBIC_LAYOUT_OPTS_NOTE" 
              	/>

				<field name="showcats" type="radio"
					label="Show Event Categories"
					description="Event categories are not linked to Joomla Categories or Tags (although they may have the same name). If shown in any section they will appear in a div as labels. The styling of the label can be specified on the CSS tab here i the Category Classes option"
					class="btn-group btn-group-yesno"
				>
					<option value="0">JHIDE</option>
					<option value="1">JSHOW</option>
				</field>
				
				<field name="endtype" type="radio"
					label="XBIC_END_OR_DUR"
					description="XBIC_END_OR_DUR_DESC"
					class="btn-group btn-group-yesno"
				>
					<option value="0">XBIC_IGNORE_END</option>
					<option value="1">XBIC_END_AS_TIME</option>
					<option value="2">XBIC_END_AS_DURATION</option>					
				</field>
				
				<field name="dtfmthelp" type="note"
					description="XBIC_TIMEFORMAT_HELP"
				/>				
				
				<field name="durationfmt" type="text"
					label="XBIC_DURATION_FMT"
					description="XBIC_DURATION_FMT_DESC"
					default=" G\h\r\s i\m\i\n\s"
					showon="endtype:2"
				/>
				
				<field name="nosection" type="note"
					description="XBIC_WARN_NO_SECTIONS"
					showon="headtype:0[AND]titletype:0[AND]infotype:0[AND]detailstype:0"
