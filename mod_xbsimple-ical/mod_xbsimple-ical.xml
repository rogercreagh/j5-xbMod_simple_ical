					showon="infotype:1"
				>
				    <form>
				        <field name="comps" type="list"
				        	label="XBIC_CAL_COMPS"
				        >
				          <option value="location">XBIC_LOCATION</option>
				          <option value="summary">XBIC_SUMMARY</option>
				          <option value="categories">XBIC_CATEGORIES</option>
				          <option value="startdate">XBIC_START_DATE</option>
				          <option value="starttime">XBIC_START_TIME</option>
				          <option value="enddate">XBIC_END_DATE</option>
				          <option value="endtime">XBIC_END_TIME_DURATION</option>
				          <option value="description">XBIC_DESCRIPTION</option>
				        </field>
				        <field name="compprefix" type="text"
				        	label="XBIC_PREFIX"
				        	hint="XBIC_PRESUF_HINT"
				        />
				        <field name="compsuffix" type="text"
				        	label="XBIC_SUFFIX"
				        	hint="XBIC_PRESUF_HINT"
				        />
				    </form>
				</field>
				
		        <field name="infodatefmt" type="text"
		        	label="XBIC_INFO_DATE_FMT"
		        	hint="XBIC_DATE_FMT_DESC"
		        	default="l jS \of F"
		        	showon="infotype:1"
		        />
								
		        <field name="infotimefmt" type="text"
		        	label="XBIC_INFO_TIME_FMT"
		        	hint="XBIC_TIME_FMT_DESC"
		        	default="G:i"
		        	showon="infotype:1"
		        />
								
				<field name="detailstype" type="radio"
					label="XBIC_DETS_SHOW"
