				<field name="headtype" type="radio"
					label="XBIC_HEAD_GROUP_OPTS"
					description="XBIC_HEAD_GROUP_OPTS_DESC"
					default="1"
					class="btn-group btn-group-yesno"
				>
					<option value="0">XBIC_NONE</option>
					<option value="1">XBIC_DATES</option>
					<option value="2">XBIC_SUMMARY</option>
					<option value="3">XBIC_LOCATION</option>
				</field>
				
				<field name="headdatefmt" type="subform"
					label="XBIC_HEAD_DATE_FMT"
					multiple="false"
					layout="joomla.form.field.subform.default"
					showon="headtype:1[OR]headtype:0"
				>
					<form>
				        <field name="startfmt" type="text"
				        	label="XBIC_START_DATE_FMT"
				        	default="D jS \of M"
				        	filter="raw"
				        />
				        <field name="endfmt" type="text"
				        	label="XBIC_END_DATE_FMT"
				        	default=" \t\o D jS"
				        	filter="raw"
				        />
					</form>					
				</field>
				
				<field type="spacer" 
				        name="titlespacer" 
				        hr="true"
				/>
				<field name="sectionnote1" type="note"					
					description="XBIC_SECTION_OPTS_NOTE"
				/>
				
				<field name="showtitle" type="radio"
					label="XBIC_TITLE_SHOW"
					default="1"
					class="btn-group btn-group-yesno"
				>
					<option value="0">JHIDE</option>
					<option value="1">JSHOW</option>
				</field>
				
				<field name="titlecomps" type="subform"
			        label="XBIC_TITLE_COMPS"
			        description="XBIC_TITLE_COMPS_DESC"
			        multiple="true"
			        min="0"  max="7"
					buttons= "add,remove,move"
					layout="joomla.form.field.subform.repeatable-table"
					showon="showtitle:1"
				>
				    <form>
				        <field name="comp" type="list"
				        	label="XBIC_CAL_COMPS"
				        >
				          <option value="summary">XBIC_SUMMARY</option>
				          <option value="startdate">XBIC_START_DATE</option>
				          <option value="enddate">XBIC_END_DATE</option>
				          <option value="repeats">XBIC_REPEATS</option>
				          <option value="starttime">XBIC_START_TIME</option>
				          <option value="endtime">XBIC_END_TIME_DURATION</option>
				          <option value="location">XBIC_LOCATION</option>
				          <option value="categories">XBIC_CATEGORIES</option>
				          <option value="calendar">XBIC_CALENDAR</option>
				        </field>
				        <field name="compprefix" type="text"
				        	label="XBIC_PREFIX"
				        	hint="XBIC_PRESUF_HINT"
				        	filter="raw"
				        />
				        <field name="compsuffix" type="text"
				        	label="XBIC_SUFFIX"
				        	hint="XBIC_PRESUF_HINT"
				        	filter="raw"
				        />
						<field name="compname" type="hidden" default="title" />
				    </form>
				</field>
												
				<field name="titledatefmt" type="subform"
					label="XBIC_TITLE_DATE_FMT"
					description="XBIC_DATE_FMT_DESC"
					multiple="false"
					layout="joomla.form.field.subform.default"
					showon="showtitle:1"
				>
					<form>
				        <field name="startfmt" type="text"
				        	label="XBIC_START_DATE_FMT"
				        	default="D jS \of M"
				        	filter="raw"
				        />
				        <field name="endfmt" type="text"
				        	label="XBIC_END_DATE_FMT"
				        	default=" \t\o D jS"
				        	filter="raw"
				        />
					</form>					
				</field>
				
				<field name="titletimefmt" type="subform"
