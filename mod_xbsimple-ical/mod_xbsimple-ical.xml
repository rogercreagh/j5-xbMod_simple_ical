				<field name="sectionnote1" type="note"					
					description="XBIC_SECTION_OPTS_NOTE"
				/>
				
				<field name="headtype" type="radio"
					label="XBIC_HEADER_SHOW"
					description="XBIC_HEADER_SHOW_DESC"
					default="1"
					class="btn-group btn-group-yesno"
				>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				
				<field name="headgroupopts" type="radio"
					label="XBIC_HEAD_GROUP_OPTS"
					description="XBIC_HEAD_GROUP_OPTS_DESC"
					default="0"
					class="btn-group btn-group-yesno"
					showon="headtype:1"
				>
					<option value="0">XBIC_START_ONLY</option>
					<option value="1">XBIC_START_END</option>
				</field>
				
		        <field name="headdatefmt" type="text"
		        	label="XBIC_HEAD_DATE_FMT"
		        	hint="XBIC_HEAD_DATE_FMT_DESC"
		        	default="l jS \of F"
		        	showon="headtype:1"
		        />
								
				<field name="titletype" type="radio"
					label="XBIC_TITLE_SHOW"
					default="1"
					class="btn-group btn-group-yesno"
				>
					<option value="0">JHIDE</option>
					<option value="1">JSHOW</option>
				</field>
				
				<field name="titlecomps" type="subform"
			        label="XBIC_TITLE_COMPS"
