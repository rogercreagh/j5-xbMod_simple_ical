				/>
				
				<field name="detsstyle" type="text"
					label="Extra Styles for Details"
					description=""
					default=""
				/>
				
				<field name="compclassnote" type="note"
					label="Classes for Individual Components"
				/>

				
				<field name="catclasses" type="text"
